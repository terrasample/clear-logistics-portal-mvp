PORT=8787
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-me-in-production
VITE_API_BASE=http://localhost:8787/api

# Stripe test key (optional for real checkout)
STRIPE_SECRET_KEY=
# Comma-separated Stripe methods for Checkout Sessions (recommended: card,link,cashapp)
STRIPE_PAYMENT_METHOD_TYPES=card,link,cashapp

# Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_EMAIL=
# Minutes before customer password reset tokens expire
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Customer quote nudge emails
# Base public URL used in unsubscribe links (defaults to http://localhost:8787)
PUBLIC_API_BASE=
# Set false to disable automated nudges
NUDGE_EMAILS_ENABLED=true
# Worker polling interval in milliseconds
NUDGE_INTERVAL_MS=300000
# Nudge timing steps in milliseconds (defaults: 1h, 24h, 72h)
NUDGE_QUOTE_STEP_1_MS=3600000
NUDGE_QUOTE_STEP_2_MS=86400000
NUDGE_QUOTE_STEP_3_MS=259200000

# Scan exception alerts
# Set false to disable scan exception alert worker
SCAN_ALERTS_ENABLED=true
# Worker polling interval in milliseconds
SCAN_ALERT_INTERVAL_MS=300000
# Repeated scan threshold within window minutes
SCAN_REPEAT_THRESHOLD=3
SCAN_REPEAT_WINDOW_MINUTES=10
# Hour in local server time to check "due today with no scans" exceptions
SCAN_NO_SCAN_CUTOFF_HOUR=14
